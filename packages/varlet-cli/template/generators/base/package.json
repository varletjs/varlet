{
  "name": "@varlet/ui",
  "version": "0.0.0",
  "description": "A components library example",
  "main": "lib/varlet.cjs.js",
  "module": "es/index.mjs",
  "typings": "types/index.d.ts",
  "web-types": "highlight/web-types.en-US.json",
  "keywords": [
    "Vue",
    "UI"
  ],
  "license": "MIT",
  "sideEffects": [
    "es/**/style/*",
    "lib/**/style/*",
    "es/style.mjs",
    "lib/style.js",
    "*.css"
  ],
  "scripts": {
    "prepare": "vp config --hooks-dir .vite-hooks && rt hook",
    "dev": "varlet-cli dev",
    "build": "varlet-cli build",
    "preview": "varlet-cli preview",
    "compile": "varlet-cli compile",
    "lint": "vp lint --fix",
    "format": "vp fmt",
    "changelog": "rt changelog",
    "release": "pnpm compile && rt release",
    "test": "varlet-cli test",
    "test:watch": "varlet-cli test -w",
    "test:coverage": "varlet-cli test -cov",
    "create": "varlet-cli create",
    "clean": "rt clean"
  },
  "peerDependencies": {
    "vue": "^3.2.0"
  },
  "devDependencies": {
    "@varlet/cli": "workspace:*",
    "@varlet/icons": "workspace:*",
    "@varlet/touch-emulator": "workspace:*",
    "@varlet/shared": "workspace:*",
    "@varlet/ui": "workspace:*",
    "@vue/test-utils": "2.4.6",
    "@vue/runtime-core": "3.5.21",
    "@vitest/coverage-istanbul": "4.1.4",
    "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.18",
    "clipboard": "^2.0.6",
    "jsdom": "26.1.0",
    "live-server": "^1.2.1",
    "rattail": "^2.0.3",
    "typescript": "5.6.3",
    "vite-plus": "0.1.18",
    "vue": "3.5.21",
    "vue-router": "4.5.1"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": "^20.19.0 || >=22.12.0",
    "pnpm": ">=9.0.0"
  }
}
